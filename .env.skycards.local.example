# Copy this file to .env.skycards.local and keep it on a trusted machine only.
# The local env file is gitignored. The exporter writes only local files.

SKYCARDS_EMAIL=you@example.com
SKYCARDS_PASSWORD=replace-with-your-password

# Optional overrides.
SKYCARDS_API_URL=https://api.skycards.oldapes.com/users/
SKYCARDS_CLIENT_VERSION=2.0.27
SKYCARDS_OUTPUT_PATH=skycards_user.json
SKYCARDS_ARCHIVE_DIR=output/skycards-user-exports
SKYCARDS_ARCHIVE_PREFIX=skycards_user
